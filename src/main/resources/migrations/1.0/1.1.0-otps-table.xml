<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="create-otps-table" author="cliffean">

        <createTable tableName="otps">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="pk_otps"
                             nullable="false"/>
            </column>

            <column name="otp_code" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="expires_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="verified" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>

            <column name="verified_at" type="TIMESTAMP"/>

            <column name="attempt_count" type="INT"/>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

        </createTable>

    </changeSet>

</databaseChangeLog>