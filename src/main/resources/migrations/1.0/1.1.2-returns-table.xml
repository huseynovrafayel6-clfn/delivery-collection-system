<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="create-returns-table" author="cliffean">

        <createTable tableName="returns">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="pk_returns"
                             nullable="false"/>
            </column>

            <column name="shipment_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_returns_shipment"
                             referencedTableName="shipments"
                             referencedColumnNames="id"/>
            </column>

            <column name="reason" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="notes" type="VARCHAR(500)"/>

            <column name="status" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="initiated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="approved_at" type="TIMESTAMP"/>

            <column name="delivered_to_sender_at" type="TIMESTAMP"/>

            <column name="completed_at" type="TIMESTAMP"/>

            <column name="initiated_by" type="BIGINT">
                <constraints nullable="true"
                             foreignKeyName="fk_returns_initiated_by"
                             referencedTableName="users"
                             referencedColumnNames="id"/>
            </column>

            <column name="approved_by" type="BIGINT">
                <constraints nullable="true"
                             foreignKeyName="fk_returns_approved_by"
                             referencedTableName="users"
                             referencedColumnNames="id"/>
            </column>

            <column name="closed" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

        </createTable>

    </changeSet>

    <changeSet id="remove-closed-column-from-returns" author="cliffean">

        <dropColumn
                tableName="returns"
                columnName="closed"/>

    </changeSet>

</databaseChangeLog>
