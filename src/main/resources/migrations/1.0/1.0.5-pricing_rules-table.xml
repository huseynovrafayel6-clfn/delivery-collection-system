<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="create-pricing-rules-table" author="chatgpt">

        <createTable tableName="pricing_rules">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="min_weight" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="max_weight" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="min_distance" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="max_distance" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="service_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="price_per_km" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="base_price" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="is_deleted" type="BOOLEAN" defaultValue="false">
                <constraints nullable="false"/>
            </column>

        </createTable>

    </changeSet>

</databaseChangeLog>