<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="create-proof-of-deliveries-table" author="cliffean">

        <createTable tableName="proof_of_deliveries">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="pk_proof_of_deliveries"
                             nullable="false"/>
            </column>

            <column name="shipment_id" type="BIGINT">
                <constraints nullable="false"
                             unique="true"
                             foreignKeyName="fk_pod_shipment"
                             referencedTableName="shipments"
                             referencedColumnNames="id"/>
            </column>

            <column name="receiver_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="receiver_phone" type="VARCHAR(50)"/>

            <column name="received_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="courier_note" type="TEXT"/>

            <column name="otp_verified" type="BOOLEAN"/>

            <column name="otp_code" type="VARCHAR(20)"/>

            <column name="signature_url" type="VARCHAR(500)"/>

            <column name="photo_url" type="VARCHAR(500)"/>

            <column name="identity_number" type="VARCHAR(100)"/>

            <column name="verification_type" type="VARCHAR(50)"/>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

        </createTable>

    </changeSet>


</databaseChangeLog>